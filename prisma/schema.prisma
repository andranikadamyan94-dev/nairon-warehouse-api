generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemType {
  CONSUMABLE
  ASSET
}

enum ResourceReturnStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum AssetStatus {
  AVAILABLE
  MAINTENANCE
  DAMAGED
  RETIRED
}

enum ResourceReservationStatus {
  PENDING
  APPROVED
  PARTIALLY_ALLOCATED
  ALLOCATED
  COMPLETED
  CANCELLED
  REJECTED
}

enum ReservationAllocationAction {
  ALLOCATED
  RELEASED
  REALLOCATED
  RETURNED
}

enum ProcurementOrderStatus {
  DRAFT
  ORDERED
  PENDING_FINANCE_APPROVAL
  FINANCE_APPROVED
  RECEIVED
  CANCELLED
}

enum ItemUnit {
  KG
  TONNE
  METER
  PIECE
  HOUR
}

model Item {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  name String
  code String? @unique

  type ItemType

  unit ItemUnit?

  quantity Float @default(0)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS

  assets Asset[]

  inventoryMovements InventoryMovement[]

  resourceReservations ResourceReservation[]

  procurementOrderItems ProcurementOrderItem[]

  categoryId Int?

  category ItemCategory? @relation(fields: [categoryId], references: [id])

  @@index([type])
}

model Asset {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  name String?

  itemId Int

  serialNumber String? @unique

  status AssetStatus @default(AVAILABLE)

  responsibleUserId Int?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  maintenanceRecords MaintenanceRecord[]

  allocations ReservationAllocation[]

  responsibilities AssetResponsibility[]

  allocationHistory ReservationAllocationHistory[]

  @@index([itemId])
  @@index([status])
}

model InventoryMovement {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  itemId Int

  quantity Float

  type String

  taskId Int?

  performedBy Int?

  notes String?

  createdAt DateTime @default(now())

  // RELATIONS

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([type])
}

model ResourceReservation {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  itemId Int

  taskId    Int?
  projectId Int?
  projectName String?

  entityId   Int?
  entityName String?

  quantity Int

  status ResourceReservationStatus @default(PENDING)

  startDate DateTime
  endDate   DateTime?

  notes String?

  replacedByReservationId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  replacedBy ResourceReservation?  @relation("ReservationReplacement", fields: [replacedByReservationId], references: [id])
  replaces   ResourceReservation[] @relation("ReservationReplacement")

  allocations ReservationAllocation[]

  allocationHistory ReservationAllocationHistory[]

  statusHistory ReservationStatusHistory[]

  returns ResourceReturn[]

  @@index([itemId])
  @@index([taskId])
  @@index([projectId])
  @@index([entityId])
  @@index([status])
  @@index([startDate, endDate])
}

model ReservationStatusHistory {
  id Int @id @default(autoincrement())

  reservationId Int

  fromStatus ResourceReservationStatus?
  toStatus   ResourceReservationStatus

  previousQuantity Int?
  newQuantity      Int?

  performedBy Int?

  reason String?

  performedAt DateTime @default(now())

  // RELATIONS

  reservation ResourceReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([performedAt])
}

model ReservationAllocation {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  reservationId Int

  assetId Int?

  quantity Int @default(1)

  allocatedAt DateTime @default(now())

  allocatedBy Int?

  releasedAt DateTime?

  // RELATIONS

  reservation ResourceReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  asset Asset? @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([assetId])
  @@index([releasedAt])
}

model ReservationAllocationHistory {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  reservationId Int

  assetId Int?

  action ReservationAllocationAction

  performedBy Int?

  notes String?

  performedAt DateTime @default(now())

  // RELATIONS

  reservation ResourceReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  asset Asset? @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([assetId])
  @@index([action])
}

model MaintenanceRecord {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  assetId Int

  startDate DateTime
  endDate   DateTime

  type String?

  notes String?

  createdBy Int?

  createdAt DateTime @default(now())

  // RELATIONS

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([startDate, endDate])
}

model AssetResponsibility {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  assetId Int

  userId Int

  assignedAt DateTime  @default(now())
  releasedAt DateTime?

  assignedBy Int?

  notes String?

  createdAt DateTime @default(now())

  // RELATIONS

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([userId])
  @@index([releasedAt])
}

model Supplier {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  name    String
  email   String?
  phone   String?
  address String?
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  procurementOrders ProcurementOrder[]
}

model ProcurementOrder {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  status ProcurementOrderStatus @default(DRAFT)

  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  notes     String?
  createdBy Int?

  financeTransferId Int?
  receivedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ProcurementOrderItem[]

  @@index([supplierId])
  @@index([status])
}

model ProcurementOrderItem {
  id      Int @id @default(autoincrement())
  orderId Int
  itemId  Int

  quantity  Float
  unitPrice Float?

  order ProcurementOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  Item              @relation(fields: [itemId],  references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([itemId])
}

model ItemCategory {
  id Int @id @default(autoincrement())

  name String

  entityId Int @default(1)

  parentId Int?

  position Int @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  parent ItemCategory? @relation("ItemCategoryHierarchy", fields: [parentId], references: [id])

  children ItemCategory[] @relation("ItemCategoryHierarchy")

  items Item[]

  @@index([entityId])
}

model ResourceReturn {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  reservationId Int
  reservation   ResourceReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  quantity Int

  status ResourceReturnStatus @default(PENDING)

  notes String?

  requestedBy Int?
  receivedBy  Int?

  requestedAt DateTime  @default(now())
  receivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reservationId])
  @@index([status])
}
